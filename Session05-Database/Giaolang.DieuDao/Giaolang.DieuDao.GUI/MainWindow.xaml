<Window x:Class="Giaolang.DieuDao.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Giaolang.DieuDao.GUI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" Loaded="Window_Loaded">
    <Grid>
        <DataGrid x:Name="FruitsDataGrid" HorizontalAlignment="Left" Height="329" Margin="46,38,0,0" VerticalAlignment="Top" Width="512" AutoGenerateColumns="False">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã TC" Width="50" Binding="{Binding Id }" />
                <DataGridTextColumn Header="Tên trái cây" Width="100" Binding="{Binding Name }" />
                <DataGridTextColumn Header="Chi tiết" Width="150" Binding="{Binding Description }" />
                <DataGridTextColumn Header="Giá" Width="80" Binding="{Binding Price }" />
                <DataGridTextColumn Header="CateId" Width="50" Binding="{Binding CategoryId }" />
                <DataGridTextColumn Header="Phân loại" Width="120" Binding="{Binding Category.Name }" />
            </DataGrid.Columns>


        </DataGrid>
        
        <Button x:Name="CreateButton" Content="Create" HorizontalAlignment="Left" Height="54" Margin="612,58,0,0" VerticalAlignment="Top" Width="119" FontSize="20" FontWeight="ExtraBold" />

        <Button x:Name="EditButton" Content="Edit" HorizontalAlignment="Left" Height="54" Margin="612,163,0,0" VerticalAlignment="Top" Width="119" FontSize="20" FontWeight="ExtraBold" />
        
        <Button x:Name="DeleteButton" Content="Delete" HorizontalAlignment="Left" Height="54" Margin="612,267,0,0" VerticalAlignment="Top" Width="119" FontSize="20" FontWeight="ExtraBold" Click="DeleteButton_Click" />

    </Grid>
</Window>
