<Window x:Class="Giaolang.DieuDao.GUI.DetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Giaolang.DieuDao.GUI"
        mc:Ignorable="d"
        Title="DetailWindow" Height="593" Width="800" WindowStartupLocation="CenterScreen" Background="#e30022" Loaded="Window_Loaded">
    <Grid>
        <Label Content="Edit Fruit Info" HorizontalAlignment="Left" Height="66" Margin="10,10,0,0" VerticalAlignment="Top" Width="286" Style="{StaticResource HeaderLabel}"/>
        <Label Content="ID:" HorizontalAlignment="Left" Height="50" Margin="36,99,0,0" VerticalAlignment="Top" Width="160"/>
        <Label Content="Name:" HorizontalAlignment="Left" Height="50" Margin="36,167,0,0" VerticalAlignment="Top" Width="160"/>
        <Label Content="Description:" HorizontalAlignment="Left" Height="50" Margin="36,243,0,0" VerticalAlignment="Top" Width="160"/>
        <Label Content="Price:" HorizontalAlignment="Left" Height="50" Margin="36,314,0,0" VerticalAlignment="Top" Width="160"/>

        <TextBox x:Name="IdTextBox" HorizontalAlignment="Left" Height="50" Margin="222,99,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="264"/>
        <TextBox x:Name="NameTextBox" HorizontalAlignment="Left" Height="50" Margin="222,167,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="264"/>
        <TextBox x:Name="DescTextBox" HorizontalAlignment="Left" Height="50" Margin="222,243,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="264"/>
        <TextBox x:Name="PriceTextBox" HorizontalAlignment="Left" Height="50" Margin="222,314,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="264"/>

        <Button x:Name="SaveButton" Content="Save" HorizontalAlignment="Left" Height="45" Margin="580,79,0,0" VerticalAlignment="Top" Width="138" Click="SaveButton_Click"/>
        <Button x:Name="ExitButton" Content="Exit" HorizontalAlignment="Left" Height="48" Margin="580,176,0,0" VerticalAlignment="Top" Width="138"/>
        <ComboBox x:Name="CateComboBox" HorizontalAlignment="Left" Height="46" Margin="222,402,0,0" VerticalAlignment="Top" Width="264"/>
        <Label Content="Category:" HorizontalAlignment="Left" Height="50" Margin="36,402,0,0" VerticalAlignment="Top" Width="160"/>




    </Grid>
</Window>
