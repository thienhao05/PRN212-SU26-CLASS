<Window x:Class="Giaolang.DieuDao.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Giaolang.DieuDao.GUI"
        mc:Ignorable="d"
        Title="Shop Điều Đào" Height="400" Width="800" Background="#ff4500" WindowStartupLocation="CenterScreen">
    <Grid>
        <Button x:Name="QuitButton" Content="Quit" HorizontalAlignment="Left" Height="31" Margin="631,74,0,0" VerticalAlignment="Top" Width="123" Click="QuitButton_Click"/>
        <Button x:Name="LoadDataButton" Content="Load Data" HorizontalAlignment="Left" Height="31" Margin="631,31,0,0" VerticalAlignment="Top" Width="123" Click="LoadDataButton_Click"/>
        <DataGrid x:Name="FruitDataGrid" HorizontalAlignment="Left" Height="150" Margin="34,192,0,0" VerticalAlignment="Top" Width="483" d:ItemsSource="{d:SampleData ItemCount=5}"/>

        <Button x:Name="CreateButton" Content="Create" HorizontalAlignment="Left" Height="44" Margin="544,199,0,0" VerticalAlignment="Top" Width="183" Style="{StaticResource LimeButton}"/>

        <Label Content="Shop Điều Đào" HorizontalAlignment="Left" Height="80" Margin="19,10,0,0" VerticalAlignment="Top" Width="402" Style="{StaticResource HeaderLabel}"/>



    </Grid>
</Window>
