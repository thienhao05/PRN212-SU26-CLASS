<Window x:Class="Giaolang.DieuDao.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Giaolang.DieuDao.GUI"
        mc:Ignorable="d"
        Title="Shop Điều Đào" Height="400" Width="800" Background="#ff4500" WindowStartupLocation="CenterScreen">
    <Grid>
        <Button x:Name="QuitButton" Content="Quit" HorizontalAlignment="Left" Height="31" Margin="54,49,0,0" VerticalAlignment="Top" Width="194" Click="QuitButton_Click"/>
        <Button x:Name="LoadDataButton" Content="Load Data" HorizontalAlignment="Left" Height="31" Margin="302,49,0,0" VerticalAlignment="Top" Width="153"/>
        <DataGrid x:Name="FruitDataGrid" HorizontalAlignment="Left" Height="126" Margin="54,133,0,0" VerticalAlignment="Top" Width="433" d:ItemsSource="{d:SampleData ItemCount=5}"/>


    </Grid>
</Window>
